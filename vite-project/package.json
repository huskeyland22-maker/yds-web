{
  "name": "vite-project",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:full": "concurrently -k -n web,api -c cyan,magenta \"vite\" \"cd .. && python server.py\"",
    "gen:build-meta": "node ./scripts/generate-build-meta.mjs",
    "embed:client-env": "node ./scripts/embed-client-env-manifest.mjs",
    "verify:api": "node ../scripts/verify-api-modules.mjs",
    "build": "npm run verify:api && npm run gen:build-meta && npm run embed:client-env && vite build",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.105.4",
    "firebase": "^12.12.1",
    "framer-motion": "^12.38.0",
    "lightweight-charts": "^4.2.3",
    "lucide-react": "^1.14.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-is": "^19.2.5",
    "react-router-dom": "^7.14.2",
    "recharts": "^3.8.1",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.2.1",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "vite": "^8.0.10",
    "vite-plugin-pwa": "^1.3.0"
  }
}
