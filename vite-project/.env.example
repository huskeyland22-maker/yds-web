# 로컬에서 Flask 없이 Render 등 공개 API만 쓸 때 (끝 슬래시 없이, /panic-data 붙이지 않음)
# 이 파일을 복사해 .env.local 로 저장한 뒤 값만 채우고, npm run dev 를 다시 실행하세요.
VITE_API_BASE=

# --- Supabase 패닉 허브 (PC/모바일/PWA 실시간 동기화) ---
# 프로덕션에서 반드시 켜야 모바일·PWA가 Render 샘플로 폴백하지 않습니다.
# 1) Supabase에서 panic_metrics + panic_index_history 마이그레이션 적용
#    (supabase/migrations/20250514120000_panic_metrics.sql,
#     supabase/migrations/20250515140000_panic_index_history.sql)
# 2) Vercel 프로젝트 환경변수: SUPABASE_URL, SUPABASE_SERVICE_ROLE_KEY
# 3) 프론트: VITE_PANIC_HUB=1, VITE_SUPABASE_URL, VITE_SUPABASE_ANON_KEY
# VITE_PANIC_HUB=1
# VITE_SUPABASE_URL=https://xxxx.supabase.co
# VITE_SUPABASE_ANON_KEY=eyJ...

# 패닉 동기화 임시 디버그 패널 (?panic-debug=1 또는 localStorage yds-panic-sync-debug=1, 개발 모드에서는 항상 표시)

# --- 매크로 브리핑 OpenAI (선택) ---
# 클라이언트: 1 이면 /api/macro-briefing-ai 호출 시도
# Vercel 서버: OPENAI_API_KEY, 선택 OPENAI_MACRO_MODEL=gpt-4o-mini
# VITE_MACRO_BRIEFING_AI=1

# --- 국내 주식 KIS API (Vercel 서버 전용, /api/stock-indicators) ---
# 국내 6자리 종목은 KIS 필수 · Yahoo 미사용. 미설정 시 503 kis_required.
# KIS_APP_KEY=
# KIS_APP_SECRET=
# KIS_USE_VIRTUAL=1
# KIS_BASE_URL=https://openapi.koreainvestment.com:9443

# Firebase Cloud Messaging (STEP 27)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_VAPID_KEY=
