# 로컬에서 Flask 없이 Render 등 공개 API만 쓸 때 (끝 슬래시 없이, /panic-data 붙이지 않음)
# 이 파일을 복사해 .env.local 로 저장한 뒤 값만 채우고, npm run dev 를 다시 실행하세요.
VITE_API_BASE=

# 데이터 흐름 추적 (프로덕션/모바일 디버그): 콘솔 [YDS_DATA] 로그 + 배지 UI
# 브라우저: ?data-trace=1 또는 localStorage yds-data-trace=1
# VITE_DATA_TRACE=1

# --- Supabase 패닉 허브 (PC/모바일/PWA 실시간 동기화) ---
# 프로덕션에서 반드시 켜야 모바일·PWA가 Render 샘플로 폴백하지 않습니다.
# 1) Supabase SQL Editor — 신규 프로젝트는 한 번에:
#    supabase/migrations/20250516120000_yds_initial_schema_seed.sql
#    (panic_metrics, panic_index_history, market_status, ai_reports + RLS + seed + realtime)
#    상세: supabase/README.md
# 2) Vercel → Settings → Environment Variables (Production + Preview + Development 모두 체크)
#    서버(API): SUPABASE_URL, SUPABASE_SERVICE_ROLE_KEY  (anon 키 아님)
#    클라이언트(빌드 시 번들 인라인 — 설정 후 반드시 Redeploy):
#      VITE_PANIC_HUB=1
#      VITE_SUPABASE_URL=https://xxxx.supabase.co
#      VITE_SUPABASE_ANON_KEY=eyJ...
#    env만 추가하고 재배포 안 하면 모바일/PWA는 계속 undefined → /client-env-manifest.json 에 clientReady:false
# VITE_PANIC_HUB=1
# VITE_SUPABASE_URL=https://xxxx.supabase.co
# VITE_SUPABASE_ANON_KEY=eyJ...

# 패닉 동기화 임시 디버그 패널 (?panic-debug=1 또는 localStorage yds-panic-sync-debug=1, 개발 모드에서는 항상 표시)

# Supabase RAW 하단 패널 (실제 query JSON — fallback 없음)
# ?supabase-debug=1 · localStorage yds-supabase-raw-debug=1 · /debug-data
# VITE_SUPABASE_RAW_DEBUG=1

# --- 매크로 브리핑 OpenAI (선택) ---
# 클라이언트: 1 이면 /api/macro-briefing-ai 호출 시도
# Vercel 서버: OPENAI_API_KEY, 선택 OPENAI_MACRO_MODEL=gpt-4o-mini
# VITE_MACRO_BRIEFING_AI=1

# --- 국내 주식 KIS API (Vercel 서버 전용, /api/stock-indicators) ---
# 국내 6자리 종목은 KIS 필수 · Yahoo 미사용. 미설정 시 503 kis_required.
# KIS_APP_KEY=
# KIS_APP_SECRET=
# KIS_USE_VIRTUAL=1
# KIS_BASE_URL=https://openapi.koreainvestment.com:9443

# Firebase Cloud Messaging (STEP 27)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_VAPID_KEY=
